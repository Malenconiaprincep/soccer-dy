VITE_GAME_SERVER_URL=http://localhost:8787
VITE_BATTLE_SOCKET_URL=ws://localhost:8788/battle
VITE_WEB_TEST_AS_DOUYIN=1
# 仅本地调试小游戏时打开；正式包不要设置为 1
VITE_DOUYIN_DEV_PANEL=0
# 抖音包不再内置 public/assets；上传抖音云/TOS 后填 HTTPS 静态资源前缀
# 例如：https://你的资源域名/soccer-dy3，前缀后面应能直接访问 /assets/...
VITE_ASSET_BASE_URL=https://your-static-domain/soccer-dy3

# 抖音云/火山 TOS 静态资源上传配置。不要把真实密钥提交到 git。
TOS_ACCESS_KEY_ID=your-tos-access-key-id
TOS_SECRET_ACCESS_KEY=your-tos-secret-access-key
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=your-tos-bucket-name
TOS_ASSET_PREFIX=soccer-dy3/assets
# 抖音云 TOS 默认私有；小游戏静态资源需要公共读。
TOS_OBJECT_ACL=public-read
# 若使用自定义域名/CDN，填自定义域名；否则可填 https://你的bucket.tos-cn-beijing.volces.com/soccer-dy3
TOS_PUBLIC_BASE_URL=https://your-bucket.tos-cn-beijing.volces.com/soccer-dy3
# 默认使用 TOS4 签名；如果你的桶只开了 S3 兼容接口，可改为 s3
TOS_SIGNING_MODE=tos

CLOUDBASE_ENV_ID=your-cloudbase-env-id
# 推荐：CloudBase 控制台 → 身份认证 → API Key 管理 → 创建「服务端 API Key」
CLOUDBASE_API_KEY=your-cloudbase-server-api-key
# 或者使用腾讯云 CAM 密钥（二选一）
# TENCENTCLOUD_SECRETID=your-tencent-secret-id
# TENCENTCLOUD_SECRETKEY=your-tencent-secret-key
# CloudBase 云存储内的资源目录，上传后为 soccer-dy3/assets/...
CLOUDBASE_ASSET_PREFIX=soccer-dy3/assets
DOUYIN_APP_ID=YOUR_DOUYIN_APP_ID
DOUYIN_APP_SECRET=YOUR_DOUYIN_APP_SECRET
SERVER_PORT=8787
SOCKET_PORT=8788
VITE_MATCH_DURATION_MS=15000
MATCH_BOT_AFTER_MS=15000
MATCH_BOTS_ENABLED=0
# 抖音支付测试环境由平台 API 参数控制；上线前按抖音后台要求调整
# 商城充值商品金额配置在 src/shopConfig.ts 的 priceCents/paymentProductId

# 阿里云百炼 DashScope API Key（控制台 → 密钥管理）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
# 中国内地默认北京节点；国际账号请改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐 qwen-flash：便宜、响应快，足够生成比赛事件；也可改 qwen-turbo / qwen-plus
DASHSCOPE_MODEL=qwen-flash
