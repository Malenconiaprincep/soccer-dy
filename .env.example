VITE_GAME_SERVER_URL=http://localhost:8787
VITE_WEB_TEST_AS_DOUYIN=1

CLOUDBASE_ENV_ID=bprecorder-d9gia565fe424bc20
# 推荐：CloudBase 控制台 → 身份认证 → API Key 管理 → 创建「服务端 API Key」
CLOUDBASE_API_KEY=your-cloudbase-server-api-key
# 或者使用腾讯云 CAM 密钥（二选一）
# TENCENTCLOUD_SECRETID=your-tencent-secret-id
# TENCENTCLOUD_SECRETKEY=your-tencent-secret-key
DOUYIN_APP_ID=YOUR_DOUYIN_APP_ID
DOUYIN_APP_SECRET=YOUR_DOUYIN_APP_SECRET
SERVER_PORT=8787
VITE_MATCH_DURATION_MS=15000
MATCH_BOT_AFTER_MS=15000

# 阿里云百炼 DashScope API Key（控制台 → 密钥管理）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
# 中国内地默认北京节点；国际账号请改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐 qwen-flash：便宜、响应快，足够生成比赛事件；也可改 qwen-turbo / qwen-plus
DASHSCOPE_MODEL=qwen-flash
