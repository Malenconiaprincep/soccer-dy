{
  "name": "soccer-dy3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 9527",
    "dev:server": "node server/dev-server.mjs",
    "dev:socket": "node server/socket-server.mjs",
    "setup:cloudbase": "node scripts/setup-cloudbase.mjs",
    "seed:cloudbase": "node scripts/seed-cloudbase.mjs",
    "test:cloudbase-login": "node scripts/test-cloudbase-login.mjs",
    "test:socket": "node scripts/test-socket-flow.mjs",
    "dev:sync": "node scripts/dev-sync.mjs",
    "build": "tsc && vite build",
    "build:douyin": "tsc && vite build --mode douyin",
    "build:douyin:debug": "tsc && vite build --mode douyin-debug",
    "debug:douyin:watch": "vite build --mode douyin-debug --watch",
    "debug:all": "node scripts/dev-sync.mjs --douyin-debug",
    "build:douyin:watch": "vite build --mode douyin --watch",
    "package:douyin": "npm run build:douyin && node -e \"require('fs').rmSync('douyin-game-clean.zip',{force:true})\" && cd douyin-game && zip -r ../douyin-game-clean.zip . -x \"*.DS_Store\" -x \"__MACOSX/*\" -x \"*/._*\" -x \"._*\"",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.1",
    "pixi.js": "^8.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
